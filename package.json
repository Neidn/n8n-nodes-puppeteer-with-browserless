{
	"name": "@ahnlabcloudmate/n8n-nodes-puppeteer-with-browserless",
	"version": "0.2.0",
	"description": "n8n community node for controlling Puppeteer via a self-hosted Browserless instance",
	"license": "MIT",
	"homepage": "https://github.com/Neidn/n8n-nodes-puppeteer-with-browserless",
	"keywords": [
		"n8n-community-node-package",
		"puppeteer",
		"browserless",
		"browser-automation",
		"web-scraping"
	],
	"author": {
		"name": "Neidn",
		"email": "dty3152@gmail.com"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/Neidn/n8n-nodes-puppeteer-with-browserless.git"
	},
	"scripts": {
		"build": "n8n-node build",
		"build:watch": "tsc --watch",
		"dev": "n8n-node dev",
		"lint": "n8n-node lint",
		"lint:fix": "n8n-node lint --fix",
		"release": "n8n-node release",
		"prepublishOnly": "pnpm run build"
	},
	"files": [
		"dist"
	],
	"n8n": {
		"n8nNodesApiVersion": 1,
		"strict": false,
		"credentials": [
			"dist/credentials/BrowserlessApi.credentials.js"
		],
		"nodes": [
			"dist/nodes/PuppeteerBrowserless/PuppeteerBrowserless.node.js"
		]
	},
	"dependencies": {
		"puppeteer-core": "^22.15.0"
	},
	"devDependencies": {
		"@n8n/node-cli": "*",
		"eslint": "9.32.0",
		"prettier": "3.6.2",
		"release-it": "^19.0.4",
		"typescript": "5.9.2",
		"puppeteer-core": "^22.15.0"
	},
	"peerDependencies": {
		"n8n-workflow": "*"
	},
	"packageManager": "pnpm@10.30.3",
	"publishConfig": {
		"registry": "https://gitea.le.ahnlabcloudmate.com/api/packages/ahnlabcloudmate/npm/"
	}
}
